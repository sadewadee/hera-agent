# =============================================================================
# Hera - Self-Improving Multi-Platform AI Agent
# Environment Variables Configuration
# =============================================================================

# --- Agent Core ---
HERA_DEFAULT_PROVIDER=openai
HERA_DEFAULT_MODEL=gpt-4o
HERA_PERSONALITY=default
HERA_SOUL_FILE=configs/SOUL.md
HERA_MAX_TOOL_CALLS=10
HERA_MEMORY_NUDGE_INTERVAL=5
HERA_SKILL_NUDGE_INTERVAL=10
HERA_SMART_ROUTING=true

# --- Compression ---
HERA_COMPRESSION_ENABLED=true
HERA_COMPRESSION_THRESHOLD=0.8
HERA_COMPRESSION_TARGET_RATIO=0.5
HERA_COMPRESSION_PROTECTED_TURNS=5
HERA_COMPRESSION_SUMMARY_MODEL=gpt-4o-mini

# --- LLM Provider API Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
NOUS_API_KEY=
HF_TOKEN=
GLM_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=

# --- Provider Base URLs (optional overrides) ---
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OLLAMA_BASE_URL=http://localhost:11434
MISTRAL_BASE_URL=https://api.mistral.ai/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
NOUS_BASE_URL=https://api.nousresearch.com/v1
HF_BASE_URL=https://api-inference.huggingface.co/models
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
KIMI_BASE_URL=https://api.moonshot.cn/v1
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# --- OpenAI Specific ---
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# --- OpenRouter Specific ---
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=Hera

# --- Memory ---
HERA_MEMORY_PROVIDER=sqlite
HERA_MEMORY_DB_PATH=~/.hera/memory.db
HERA_MEMORY_MAX_RESULTS=10

# --- Gateway ---
HERA_SESSION_TIMEOUT=30
HERA_HUMAN_DELAY=true
HERA_DELAY_MS_PER_CHAR=30
HERA_ALLOW_ALL=false

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOW_LIST=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# --- Discord ---
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ALLOW_LIST=

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_ALLOW_LIST=

# --- WhatsApp ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_SIDECAR_URL=http://localhost:3001

# --- Signal ---
SIGNAL_CLI_PATH=/usr/local/bin/signal-cli
SIGNAL_PHONE_NUMBER=
SIGNAL_DATA_PATH=~/.local/share/signal-cli

# --- Matrix ---
MATRIX_HOMESERVER=
MATRIX_USER_ID=
MATRIX_ACCESS_TOKEN=
MATRIX_DEVICE_ID=

# --- Email (IMAP/SMTP) ---
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=
EMAIL_POLL_INTERVAL=60

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_URL=

# --- Home Assistant ---
HOMEASSISTANT_URL=http://homeassistant.local:8123
HOMEASSISTANT_TOKEN=
HOMEASSISTANT_WEBHOOK_ID=

# --- DingTalk ---
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_ROBOT_CODE=
DINGTALK_WEBHOOK_TOKEN=

# --- Feishu (Lark) ---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# --- WeCom (WeChat Work) ---
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_AGENT_ID=
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_AES_KEY=

# --- Mattermost ---
MATTERMOST_URL=
MATTERMOST_TOKEN=
MATTERMOST_TEAM_ID=
MATTERMOST_CHANNEL_ID=

# --- BlueBubbles (iMessage) ---
BLUEBUBBLES_URL=http://localhost:1234
BLUEBUBBLES_PASSWORD=

# --- Webhook (Generic) ---
WEBHOOK_LISTEN_ADDR=:8090
WEBHOOK_SECRET=
WEBHOOK_CALLBACK_URL=

# --- API Server ---
API_SERVER_LISTEN_ADDR=:8080
API_SERVER_AUTH_TOKEN=

# --- ACP (Agent Client Protocol) ---
ACP_LISTEN_ADDR=:8081
ACP_JWT_SECRET=
ACP_TOKEN_EXPIRY=24h

# --- MCP Server ---
MCP_TRANSPORT=stdio

# --- Cron ---
HERA_CRON_ENABLED=false
HERA_CRON_DB_PATH=~/.hera/cron.db

# --- Security ---
HERA_REDACT_PII=false
HERA_PROTECTED_PATHS=/etc,/var/lib
HERA_DANGEROUS_APPROVE=false

# --- CLI ---
HERA_SKIN=default
HERA_PROFILE=default

# --- Tools ---
EXA_API_KEY=
FIRECRAWL_API_KEY=
FAL_API_KEY=
ELEVENLABS_API_KEY=

# --- Skills Hub ---
HERA_SKILLS_HUB_URL=https://skills.hera.ai
HERA_SKILLS_DIR=~/.hera/skills

# --- Logging ---
HERA_LOG_LEVEL=info
HERA_LOG_FORMAT=text

# --- Docker / Deployment ---
HERA_DATA_DIR=/data/hera
HERA_CONFIG_FILE=/etc/hera/hera.yaml
