# Hera Environment Variables
# Copy this to ~/.hera/.env and fill in your API keys

# LLM Provider API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=

# Tool API Keys
EXA_API_KEY=
FIRECRAWL_API_KEY=
FAL_API_KEY=

# Platform Tokens (Gateway)
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional
HERA_LOG_LEVEL=info
